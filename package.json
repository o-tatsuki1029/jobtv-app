{
  "name": "jobtv-app",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "types": "supabase gen types typescript --project-id tdewumilkltljbqryjpg > packages/shared/types/database.types.ts",
    "types:all": "turbo run types",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "db:link:stg": "supabase link --project-ref tdewumilkltljbqryjpg",
    "db:link:prod": "supabase link --project-ref voisychklptvavokrxox",
    "db:push:stg": "supabase link --project-ref tdewumilkltljbqryjpg && supabase db push",
    "db:push:prod": "supabase link --project-ref voisychklptvavokrxox && supabase db push"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "dotenv": "^16.0.0",
    "otplib": "^12.0.1",
    "pino-pretty": "^13.1.3",
    "turbo": "^2.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase",
      "sharp",
      "core-js",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "pino": "^10.3.1"
  }
}
